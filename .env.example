# Postgres connection string — free tier from https://supabase.com or https://neon.tech works fine
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Basic auth for /admin (Phase 1). Change these before deploying.
ADMIN_USER="admin"
ADMIN_PASS="changeme"

