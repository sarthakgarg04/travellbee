// Prisma schema for Travell Bee
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Destination {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  code        String
  tagline     String
  description String
  coverImage  String
  packages    Package[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Package {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  destination     Destination    @relation(fields: [destinationId], references: [id])
  destinationId   String
  durationDays    Int
  priceInInr      Int
  offerPriceInInr Int?
  offerEndsAt     DateTime?
  coverImage      String
  summary         String
  inclusions      String[]       @default([])
  exclusions      String[]       @default([])
  itinerary       Json
  themes          String[]       @default([])
  featured        Boolean        @default(false)
  status          PackageStatus  @default(DRAFT)
  images          PackageImage[]
  enquiries       Enquiry[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, featured])
  @@index([destinationId, status])
}

model PackageImage {
  id        String  @id @default(cuid())
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId String
  url       String
  publicId  String?
  alt       String  @default("")
  order     Int     @default(0)

  @@index([packageId, order])
}

model Enquiry {
  id         String    @id @default(cuid())
  name       String
  phone      String
  email      String?
  travelDate DateTime?
  travelers  Int       @default(1)
  message    String?
  package    Package?  @relation(fields: [packageId], references: [id], onDelete: SetNull)
  packageId  String?
  status     String    @default("new")
  source     String    @default("web")
  createdAt  DateTime  @default(now())

  @@index([status, createdAt])
}