generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Destination {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  code        String
  tagline     String
  description String
  coverImage  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  packages    Package[]
}

model Package {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  destinationId   String
  durationDays    Int
  priceInInr      Int
  offerPriceInInr Int?
  offerEndsAt     DateTime?
  coverImage      String
  summary         String
  inclusions      String[]       @default([])
  exclusions      String[]       @default([])
  itinerary       Json
  themes          String[]       @default([])
  featured        Boolean        @default(false)
  status          PackageStatus  @default(DRAFT)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  mapQuery        String?
  places          Json?
  enquiries       Enquiry[]
  destination     Destination    @relation(fields: [destinationId], references: [id])
  images          PackageImage[]
  reviews         Review[]

  @@index([status, featured])
  @@index([destinationId, status])
}

model PackageImage {
  id        String  @id @default(cuid())
  packageId String
  url       String
  publicId  String?
  alt       String  @default("")
  order     Int     @default(0)
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, order])
}

model Enquiry {
  id         String    @id @default(cuid())
  name       String
  phone      String
  email      String?
  travelDate DateTime?
  travelers  Int       @default(1)
  message    String?
  packageId  String?
  status     String    @default("new")
  source     String    @default("web")
  createdAt  DateTime  @default(now())
  package    Package?  @relation(fields: [packageId], references: [id])

  @@index([status, createdAt])
}

model Review {
  id          String       @id @default(cuid())
  packageId   String
  authorName  String
  authorEmail String
  rating      Int
  title       String       @default("")
  body        String
  verified    Boolean      @default(false)
  status      ReviewStatus @default(PENDING)
  travelDate  DateTime?
  createdAt   DateTime     @default(now())
  package     Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, authorEmail])
  @@index([packageId, status])
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
